/**
 * TypeScript compiler configuration.
 *
 * Vite uses esbuild for transpilation; TypeScript is used for type-checking
 * only. That is why `noEmit: true` is set with no `outDir`.
 *
 * The full strict flag group is intentionally kept enabled — these rules
 * catch real bugs before runtime and are non-negotiable in this codebase.
 */
{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode — mirrors Vite/esbuild module resolution at compile time. */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strict type checking */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}